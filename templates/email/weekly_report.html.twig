<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weekly Report — {{ kpis.week_start }} – {{ kpis.week_end }}</title>
</head>
<body>
    <h1>Weekly Report — {{ kpis.week_start }} – {{ kpis.week_end }}</h1>

    <table>
