            <tr>
                <th>New users</th>
                <td>{{ kpis.new_users }}</td>
            </tr>
            <tr>
                <th>Total users</th>
                <td>{{ kpis.total_users }}</td>
            </tr>
        </tbody>
    </table>
</body>
</html>
