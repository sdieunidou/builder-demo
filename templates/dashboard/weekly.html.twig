{% extends 'base.html.twig' %}

{% block title %}Weekly KPI Dashboard{% endblock %}

{% block body %}
<div class="p-8">
    <h1 class="text-2xl font-bold mb-6">
        Weekly KPIs: {{ week_start }} – {{ week_end }}
    </h1>

    <div class="flex gap-6">
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm w-48">
            <p class="text-sm text-gray-500 mb-1">New users this week</p>
            <p class="text-3xl font-semibold text-indigo-600">{{ new_users }}</p>
        </div>

        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm w-48">
            <p class="text-sm text-gray-500 mb-1">Total users</p>
            <p class="text-3xl font-semibold text-indigo-600">{{ total_users }}</p>
        </div>
    </div>
</div>
{% endblock %}
